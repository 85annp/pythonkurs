generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}


model User {
  id            String    @id @default(cuid())
  username      String    @unique
  password      String
  name          String?
  role          String    @default("STUDENT") // STUDENT or TEACHER
  progress      Progress[]
}

model Module {
  id          String     @id @default(cuid())
  slug        String     @unique // e.g., "komma-igang"
  title       String
  description String?
  order       Int
  progress    Progress[]
}

model Progress {
  id        String   @id @default(cuid())
  userId    String
  moduleId  String
  status    String   @default("NOT_STARTED") // NOT_STARTED, IN_PROGRESS, COMPLETED
  savedCode String?  // Stores the user's latest code for this module
  teacherApproved Boolean @default(false) // Whether the teacher has approved this code
  updatedAt DateTime @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  module Module @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@unique([userId, moduleId])
}
